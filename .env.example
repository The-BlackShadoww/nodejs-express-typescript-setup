# ──────────────────────────────────────────────────────────────
# Environment Variables — nodejs-express-project-setup-with-typescript
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# ─── Server ───────────────────────────────────────────────────
# Port the Express server listens on (default: 8000)
PORT=8000

# Environment mode: development | production | test
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────
# MongoDB connection string (without database name — appended automatically)
MONGODB_URI=mongodb://localhost:27017

# ─── CORS ─────────────────────────────────────────────────────
# Allowed origin for cross-origin requests (e.g., your frontend URL)
CORS_ORIGIN=*

# ─── Authentication (JWT) ────────────────────────────────────
# Secret key for signing access tokens (use a strong random string)
ACCESS_TOKEN_SECRET=your_access_token_secret_here

# How long access tokens remain valid (e.g., "1d", "15m", "2h")
ACCESS_TOKEN_EXPIRY=1d

# Secret key for signing refresh tokens (use a different strong random string)
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# How long refresh tokens remain valid (e.g., "10d", "30d")
REFRESH_TOKEN_EXPIRY=10d

# ─── Cloudinary (Media Uploads) ──────────────────────────────
# Get these from your Cloudinary dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
